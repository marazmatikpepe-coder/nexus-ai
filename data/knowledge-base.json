// ============ САМООБУЧЕНИЕ NEXUS ============
const NexusLearning = {
    isLearning: false,
    lastLearnTime: null,

    async startBackgroundLearning() {
        if (this.isLearning) return;
        
        this.isLearning = true;
        NexusUI.showLearningIndicator();
        console.log('📚 Nexus начал фоновое обучение...');

        try {
            // 1. Учимся из Wikipedia
            await this.learnFromWikipedia();
            
            // 2. Анализируем сохраненные диалоги
            await this.analyzeConversations();
            
            // 3. Обновляем базу знаний
            await this.updateKnowledgeBase();
            
            this.lastLearnTime = new Date();
            console.log('✅ Обучение завершено');
            
        } catch (error) {
            console.log('⚠️ Обучение прервано:', error.message);
        } finally {
            this.isLearning = false;
        }
    },

    async learnFromWikipedia() {
        try {
            const topics = [
                'Искусственный_интеллект',
                'Нейронная_сеть',
                'Машинное_обучение',
                'Квантовый_компьютер',
                'Программирование'
            ];

            for (const topic of topics) {
                const response = await fetch(
                    `https://ru.wikipedia.org/w/api.php?action=query&prop=extracts&exintro=1&explaintext=1&titles=${topic}&format=json&origin=*`
                );
                
                const data = await response.json();
                const pages = data.query.pages;
                const page = Object.values(pages)[0];
                
                if (page.extract) {
                    const summary = page.extract.substring(0, 500);
                    const topicKey = topic.toLowerCase().replace(/_/g, ' ');
                    
                    // Сохраняем в Firestore
                    await NexusMemory.addKnowledge(topicKey, {
                        text: summary,
                        source: 'wikipedia',
                        timestamp: new Date().toISOString()
                    });
                }
                
                // Задержка чтобы не нагружать API
                await this.sleep(2000);
            }
        } catch (error) {
            console.log('📖 Wikipedia недоступна');
        }
    },

    async analyzeConversations() {
        try {
            const snapshot = await db.collection('conversations')
                .orderBy('timestamp', 'desc')
                .limit(20)
                .get();

            const conversations = [];
            snapshot.forEach(doc => {
                conversations.push(doc.data());
            });

            // Анализируем частые темы
            const topics = {};
            conversations.forEach(conv => {
                const words = conv.user.toLowerCase().split(/\s+/);
                words.forEach(word => {
                    if (word.length > 4) {
                        topics[word] = (topics[word] || 0) + 1;
                    }
                });
            });

            // Находим топ темы
            const topTopics = Object.entries(topics)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 5);

            console.log('📊 Популярные темы:', topTopics);

        } catch (error) {
            console.log('💬 Анализ диалогов пропущен');
        }
    },

    async updateKnowledgeBase() {
        console.log('🔄 Обновление базы знаний...');
        // Здесь можно добавить обновление knowledge-base.json
    },

    sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }
};

// Автообучение при загрузке
setTimeout(() => {
    NexusLearning.startBackgroundLearning();
}, 10000); // Через 10 секунд после загрузки
